# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/kastra

# JWT
SECRET_KEY=your-256-bit-secret-key-here
REFRESH_SECRET_KEY=your-separate-refresh-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# App
FRONTEND_URL=http://localhost:5200
BACKEND_URL=http://localhost:8080
ENVIRONMENT=development

# M-Pesa
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-passkey
MPESA_CALLBACK_URL=https://api.kastra.co.ke/api/mpesa/callback
MPESA_ENV=sandbox

# Email (optional)
SENDGRID_API_KEY=your-sendgrid-api-key
MAIL_FROM=noreply@kastra.co.ke

# Paystack card payments — get keys from paystack.com/dashboard
PAYSTACK_SECRET_KEY=sk_test_your-secret-key
PAYSTACK_PUBLIC_KEY=pk_test_your-public-key

# Africa's Talking SMS — set AT_API_KEY to enable SMS notifications to clients
# Get keys at https://africastalking.com — use 'sandbox' username for testing
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=
AT_WHATSAPP_NUMBER=

# Claude AI — used for OCR receipt scanning
ANTHROPIC_API_KEY=

# Cloudinary — photo storage for projects
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Field-level encryption for stored credentials (Paystack keys, M-Pesa secrets, eTIMS token)
# Generate a key once and keep it safe — losing it makes stored credentials unreadable:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# Error tracking (optional — leave blank in development)
SENTRY_DSN=

# Super admin — change these before going to production!
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me-superadmin
SUPERADMIN_SECRET_KEY=change-me-superadmin-secret-32chars
